<Window x:Class="Englishtest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="英文單字練習App V0.5" Height="680" Width="680"
        MinHeight="600" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8"
        Closed="Window_Closed">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="中英翻譯練習" FontSize="22" FontWeight="Bold" Foreground="#1A1A2E"/>
            <TextBlock Grid.Column="1" x:Name="ScoreText" Text="得分：0 / 0" FontSize="14" Foreground="#5C6B7A" VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="SessionInfoText" Text=""
                       FontSize="14" Foreground="#475569" VerticalAlignment="Center"/>
            <Button Grid.Column="1" x:Name="RestartButton" Content="重新選擇" Height="32" Padding="12,0"
                    Click="RestartButton_Click"
                    Background="#F1F5F9" Foreground="#475569" BorderBrush="#CBD5E1" BorderThickness="1"/>
        </Grid>

        <Border Grid.Row="2" Margin="0,16,0,16" Background="White" CornerRadius="12"
                BorderBrush="#E2E8F0" BorderThickness="1" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="12,10" CornerRadius="8" Background="#F8FAFC" Margin="0,0,0,12">
                    <TextBlock x:Name="ChineseText" Text="載入中…"
                               FontSize="32" FontWeight="Bold" Foreground="#2563EB"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock x:Name="PhoneticPlaceholderText" Text="（點擊「播放發音」查看音標；有詞源資料時顯示字根）"
                                   FontSize="13" Foreground="#94A3B8" FontStyle="Italic"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>

                        <TextBlock x:Name="PhoneticText" Text="" Visibility="Collapsed"
                                   FontSize="18" Foreground="#64748B" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   Margin="0,8,0,0"/>

                        <Border x:Name="RootsSection" Visibility="Collapsed" Margin="0,12,0,0"
                                Padding="12,10" CornerRadius="8" Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1">
                            <StackPanel>
                                <TextBlock x:Name="RootsTitleText" Text=""
                                           FontSize="12" Foreground="#92400E" Margin="0,0,0,8"/>
                                <WrapPanel x:Name="RootsWrapPanel" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="RootHintText" Text="" TextWrapping="Wrap"
                                           FontSize="12" Foreground="#78350F" Margin="0,8,0,0"
                                           HorizontalAlignment="Center" TextAlignment="Center"/>
                                <TextBlock x:Name="EtymologySummaryText" Text="" TextWrapping="Wrap" Visibility="Collapsed"
                                           FontSize="12" Foreground="#78350F" Margin="0,6,0,0"
                                           HorizontalAlignment="Center" TextAlignment="Center"/>
                                <TextBlock Margin="0,8,0,0" HorizontalAlignment="Center" FontSize="12">
                                    <Hyperlink x:Name="WiktionaryLink" Click="WiktionaryLink_Click"
                                               Foreground="#B45309" TextDecorations="None">
                                        在 Wiktionary 查看完整詞源
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,4">
                            <Button x:Name="PlayButton" Content="播放發音" Width="110" Height="34" Margin="0,0,12,0"
                                    Click="PlayButton_Click"
                                    Background="#EFF6FF" Foreground="#1D4ED8" BorderBrush="#BFDBFE" BorderThickness="1"/>
                            <Button x:Name="DictionaryButton" Content="查看線上字典" Height="34" Padding="12,0"
                                    Click="DictionaryButton_Click" IsEnabled="False"
                                    Background="Transparent" Foreground="#2563EB" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <TextBlock x:Name="PromptLabel" Grid.Row="3" Text="請輸入英文翻譯：" FontSize="14" Foreground="#475569" Margin="0,0,0,8"/>

        <TextBox x:Name="AnswerBox" Grid.Row="4" FontSize="18" Padding="12,10"
                 VerticalContentAlignment="Center"
                 BorderBrush="#CBD5E1" BorderThickness="1"
                 KeyDown="AnswerBox_KeyDown"/>

        <Border x:Name="FeedbackPanel" Grid.Row="5" Margin="0,16,0,0" Padding="14,10"
                CornerRadius="8" Visibility="Collapsed">
            <TextBlock x:Name="FeedbackText" TextWrapping="Wrap" FontSize="15"/>
        </Border>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button x:Name="NextButton" Content="下一題" Width="100" Height="40" Margin="0,0,12,0"
                    Click="NextButton_Click" IsEnabled="False"
                    Background="#E2E8F0" Foreground="#334155" BorderThickness="0"/>
            <Button x:Name="SubmitButton" Content="送出答案" Width="120" Height="40"
                    Click="SubmitButton_Click"
                    Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
