<Window x:Class="Englishtest.GuideReadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="導讀練習" Height="720" Width="720"
        MinHeight="560" MinWidth="560"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8"
        Closed="Window_Closed">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="導讀練習" FontSize="22" FontWeight="Bold" Foreground="#1A1A2E"/>
        <Grid Grid.Row="1" Margin="0,8,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="SubtitleText" Text="內容來自 read.txt，可調整朗讀速度與跟讀"
                       FontSize="14" Foreground="#64748B" VerticalAlignment="Center" TextWrapping="Wrap"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="LoadDefaultButton" Content="預設文章" Width="80" Height="28" Margin="0,0,8,0"
                        Click="LoadDefaultButton_Click" Background="#F1F5F9" Foreground="#475569" BorderBrush="#CBD5E1"
                        FontWeight="SemiBold" Cursor="Hand"/>
                <Button x:Name="LoadFriendsButton" Content="🎬 隨機六人行對話" Width="130" Height="28"
                        Click="LoadFriendsButton_Click" Background="#EFF6FF" Foreground="#1D4ED8" BorderBrush="#BFDBFE"
                        FontWeight="SemiBold" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Margin="0,0,0,12" Padding="14,12" Background="White"
                CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="朗讀速度" FontSize="14" Foreground="#475569" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" x:Name="SpeedSlider" Minimum="-8" Maximum="8" Value="0"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center" Margin="16,0"
                            ValueChanged="SpeedSlider_ValueChanged"/>
                    <TextBlock Grid.Column="2" x:Name="SpeedLabel" Text="正常" FontSize="14" FontWeight="SemiBold"
                               Foreground="#2563EB" VerticalAlignment="Center" MinWidth="72" TextAlignment="Right"/>
                </Grid>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="選擇語音" FontSize="14" Foreground="#475569" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" x:Name="VoiceComboBox" Height="34" Margin="16,0,0,0" FontSize="13" 
                              VerticalContentAlignment="Center" SelectionChanged="VoiceComboBox_SelectionChanged"/>
                </Grid>
                <TextBlock x:Name="ProgressText" Text="" FontSize="13" Foreground="#64748B" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="White" CornerRadius="12"
                BorderBrush="#E2E8F0" BorderThickness="1" Padding="12">
            <ScrollViewer x:Name="ContentScroll" VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="SegmentList" BorderThickness="0" Background="Transparent"
                         SelectionChanged="SegmentList_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#EFF6FF"/>
                                                <Setter Property="Foreground" Value="#1E40AF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="15" LineHeight="22"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="4" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" x:Name="PlayButton" Content="開始朗讀" Width="100" Height="40"
                    Click="PlayButton_Click"
                    Background="#2563EB" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Grid.Column="3" x:Name="PauseButton" Content="暫停" Width="80" Height="40"
                    Click="PauseButton_Click" IsEnabled="False"
                    Background="#F1F5F9" Foreground="#475569" BorderBrush="#CBD5E1" BorderThickness="1"/>
            <Button Grid.Column="5" x:Name="StopButton" Content="停止" Width="80" Height="40"
                    Click="StopButton_Click" IsEnabled="False"
                    Background="#F1F5F9" Foreground="#475569" BorderBrush="#CBD5E1" BorderThickness="1"/>
            <Button Grid.Column="7" x:Name="ShowChineseButton" Content="顯示中文" Width="88" Height="40"
                    Click="ShowChineseButton_Click" Visibility="Collapsed"
                    Background="#EFF6FF" Foreground="#1D4ED8" BorderBrush="#BFDBFE" BorderThickness="1"/>
            <Button Grid.Column="9" Content="關閉" Width="80" Height="40" IsCancel="True"
                    Background="#E2E8F0" Foreground="#334155" BorderThickness="0"/>
        </Grid>
    </Grid>
</Window>
