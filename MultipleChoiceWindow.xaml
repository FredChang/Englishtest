<Window x:Class="Englishtest.MultipleChoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="英文單字選擇題 V0.4" Height="620" Width="640"
        MinHeight="550" MinWidth="560"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8"
        Closed="Window_Closed">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="TitleText" Text="選擇題" FontSize="22" FontWeight="Bold" Foreground="#1A1A2E"/>
            <TextBlock Grid.Column="1" x:Name="ScoreText" Text="得分：0 / 0" FontSize="14" Foreground="#5C6B7A" VerticalAlignment="Center"/>
        </Grid>

        <!-- Session info -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="SessionInfoText" Text=""
                       FontSize="14" Foreground="#475569" VerticalAlignment="Center"/>
            <Button Grid.Column="1" x:Name="RestartButton" Content="重新選擇" Height="32" Padding="12,0"
                    Click="RestartButton_Click"
                    Background="#F1F5F9" Foreground="#475569" BorderBrush="#CBD5E1" BorderThickness="1"/>
        </Grid>

        <!-- Question prompt -->
        <Border Grid.Row="2" Margin="0,20,0,0" Padding="16,14" CornerRadius="12"
                Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>
                <TextBlock x:Name="PromptLabel" Text="請選出正確的英文翻譯：" FontSize="13" Foreground="#94A3B8" Margin="0,0,0,8"/>
                <TextBlock x:Name="QuestionText" Text="載入中…"
                           FontSize="30" FontWeight="Bold" Foreground="#2563EB"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 4 choice buttons -->
        <Grid Grid.Row="3" Margin="0,20,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="OptionA" Grid.Row="0" Grid.Column="0" Click="Option_Click" Tag="0"
                    FontSize="17" FontWeight="SemiBold" Cursor="Hand"
                    Background="White" Foreground="#334155" BorderBrush="#CBD5E1" BorderThickness="1.5">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="14,12" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#93C5FD"/>
                                <Setter TargetName="Bd" Property="Background" Value="#F0F9FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="OptionB" Grid.Row="0" Grid.Column="2" Click="Option_Click" Tag="1"
                    FontSize="17" FontWeight="SemiBold" Cursor="Hand"
                    Background="White" Foreground="#334155" BorderBrush="#CBD5E1" BorderThickness="1.5">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="14,12" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#93C5FD"/>
                                <Setter TargetName="Bd" Property="Background" Value="#F0F9FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="OptionC" Grid.Row="2" Grid.Column="0" Click="Option_Click" Tag="2"
                    FontSize="17" FontWeight="SemiBold" Cursor="Hand"
                    Background="White" Foreground="#334155" BorderBrush="#CBD5E1" BorderThickness="1.5">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="14,12" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#93C5FD"/>
                                <Setter TargetName="Bd" Property="Background" Value="#F0F9FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="OptionD" Grid.Row="2" Grid.Column="2" Click="Option_Click" Tag="3"
                    FontSize="17" FontWeight="SemiBold" Cursor="Hand"
                    Background="White" Foreground="#334155" BorderBrush="#CBD5E1" BorderThickness="1.5">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="14,12" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#93C5FD"/>
                                <Setter TargetName="Bd" Property="Background" Value="#F0F9FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Feedback -->
        <Border x:Name="FeedbackPanel" Grid.Row="4" Margin="0,16,0,0" Padding="14,10"
                CornerRadius="8" Visibility="Collapsed">
            <TextBlock x:Name="FeedbackText" TextWrapping="Wrap" FontSize="15"/>
        </Border>

        <!-- Next button -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="NextButton" Content="下一題 →" Width="120" Height="40"
                    Click="NextButton_Click" IsEnabled="False"
                    Background="#2563EB" Foreground="White" FontWeight="Bold" BorderThickness="0" FontSize="15"/>
        </StackPanel>
    </Grid>
</Window>
